@page "/einstellungen"
@using Einsatzueberwachung.Domain.Interfaces
@using Einsatzueberwachung.Domain.Models
@using Einsatzueberwachung.Domain.Services
@inject ISettingsService SettingsService
@inject IMasterDataService MasterDataService
@inject ThemeService ThemeService
@inject IJSRuntime JS
@inject ToastService ToastService
@rendermode InteractiveServer

<PageTitle>Einstellungen</PageTitle>

<div class="settings-container">
    <div class="page-header">
        <h1><i class="bi bi-gear-fill"></i> Einstellungen</h1>
        <p class="text-muted">Staffel-Daten und App-Konfiguration</p>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <div class="card mb-4">
                <div class="card-header">
                    <h4><i class="bi bi-building"></i> Staffel-Informationen</h4>
                </div>
                <div class="card-body">
                    <EditForm Model="@_staffelSettings" OnValidSubmit="@SaveStaffelSettings">
                        <div class="form-group mb-3">
                            <label class="form-label">Staffel-Name</label>
                            <InputText @bind-Value="_staffelSettings.StaffelName" class="form-control form-control-lg" placeholder="z.B. RHS Speyer" />
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">Adresse</label>
                            <InputTextArea @bind-Value="_staffelSettings.StaffelAdresse" class="form-control" rows="3" placeholder="Straße, PLZ Ort" />
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">Telefon</label>
                            <InputText @bind-Value="_staffelSettings.StaffelTelefon" class="form-control form-control-lg" placeholder="+49 123 456789" />
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">E-Mail</label>
                            <InputText @bind-Value="_staffelSettings.StaffelEmail" class="form-control form-control-lg" placeholder="kontakt@staffel.de" />
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">Logo-Pfad</label>
                            <InputText @bind-Value="_staffelSettings.StaffelLogoPfad" class="form-control form-control-lg" placeholder="Pfad zum Logo" />
                            <small class="text-muted">Pfad zu einer Bilddatei für den PDF-Export</small>
                        </div>

                        <button type="submit" class="btn btn-success btn-lg w-100">
                            <i class="bi bi-save-fill"></i> Speichern
                        </button>
                    </EditForm>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card mb-4">
                <div class="card-header">
                    <h4><i class="bi bi-palette-fill"></i> Darstellung</h4>
                </div>
                <div class="card-body">
                    <EditForm Model="@_appSettings" OnValidSubmit="@SaveAppSettings">
                        <div class="form-group mb-3">
                            <label class="form-label">Theme-Modus</label>
                            <select class="form-select form-select-lg mb-3" @bind="_appSettings.ThemeMode" @bind:after="OnThemeModeChanged">
                                <option value="Manual">Manuell (per Button umschalten)</option>
                                <option value="Auto">Automatisch (folgt System)</option>
                                <option value="Scheduled">Zeitgesteuert</option>
                            </select>
                        </div>

                        @if (_appSettings.ThemeMode == "Manual")
                        {
                            <div class="form-group mb-3">
                                <label class="form-label">Design-Modus</label>
                                <div class="btn-group w-100" role="group">
                                    <button type="button" 
                                            class="btn btn-lg @(!_appSettings.IsDarkMode ? "btn-light" : "btn-outline-light")"
                                            @onclick="() => ToggleDarkMode(false)">
                                        <i class="bi bi-sun-fill"></i> Hell
                                    </button>
                                    <button type="button" 
                                            class="btn btn-lg @(_appSettings.IsDarkMode ? "btn-dark" : "btn-outline-dark")"
                                            @onclick="() => ToggleDarkMode(true)">
                                        <i class="bi bi-moon-fill"></i> Dunkel
                                    </button>
                                </div>
                            </div>
                        }

                        @if (_appSettings.ThemeMode == "Scheduled")
                        {
                            <div class="alert alert-info mb-3">
                                <i class="bi bi-info-circle-fill"></i> Dark Mode wird automatisch zur eingestellten Zeit aktiviert.
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">Dark Mode Start</label>
                                    <input type="time" 
                                           class="form-control form-control-lg" 
                                           value="@FormatTimeSpan(_appSettings.DarkModeStartTime)"
                                           @onchange="e => _appSettings.DarkModeStartTime = ParseTimeSpan(e.Value?.ToString())" />
                                    <small class="text-muted">Wechsel zu Dark Mode</small>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Dark Mode Ende</label>
                                    <input type="time" 
                                           class="form-control form-control-lg" 
                                           value="@FormatTimeSpan(_appSettings.DarkModeEndTime)"
                                           @onchange="e => _appSettings.DarkModeEndTime = ParseTimeSpan(e.Value?.ToString())" />
                                    <small class="text-muted">Wechsel zu Light Mode</small>
                                </div>
                            </div>
                        }

                        @if (_appSettings.ThemeMode == "Auto")
                        {
                            <div class="alert alert-info mb-3">
                                <i class="bi bi-info-circle-fill"></i> Dark Mode folgt automatisch den System-Einstellungen Ihres Betriebssystems.
                            </div>
                        }

                        <hr/>

                        <h5 class="mb-3"><i class="bi bi-alarm-fill"></i> Timer-Warnungen (Standard)</h5>

                        <div class="form-group mb-3">
                            <label class="form-label">Erste Warnung (Minuten)</label>
                            <InputNumber @bind-Value="_appSettings.DefaultFirstWarningMinutes" class="form-control form-control-lg" />
                            <small class="text-muted">Standard: 45 Minuten</small>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">Zweite Warnung (Minuten)</label>
                            <InputNumber @bind-Value="_appSettings.DefaultSecondWarningMinutes" class="form-control form-control-lg" />
                            <small class="text-muted">Standard: 60 Minuten</small>
                        </div>

                        <hr/>

                        <h5 class="mb-3"><i class="bi bi-volume-up-fill"></i> Sound-Warnungen</h5>

                        <div class="form-check form-switch mb-3">
                            <InputCheckbox @bind-Value="_appSettings.SoundAlertsEnabled" class="form-check-input" id="soundEnabled" />
                            <label class="form-check-label" for="soundEnabled">
                                <i class="bi bi-bell-fill"></i> Akustische Warnungen aktiviert
                            </label>
                        </div>

                        @if (_appSettings.SoundAlertsEnabled)
                        {
                            <div class="form-group mb-3">
                                <label class="form-label">Lautstärke: @_appSettings.SoundVolume%</label>
                                <input type="range" class="form-range" min="0" max="100" step="5"
                                       value="@_appSettings.SoundVolume"
                                       @onchange="OnVolumeChanged" />
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">Erste Warnung - Sound</label>
                                    <select class="form-select" @bind="_appSettings.FirstWarningSound">
                                        <option value="beep">🔔 Beep (Standard)</option>
                                        <option value="bell">🔔 Glocke</option>
                                        <option value="alarm">🚨 Alarm</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Frequenz (Hz)</label>
                                    <InputNumber @bind-Value="_appSettings.FirstWarningFrequency" class="form-control" min="200" max="2000" />
                                    <small class="text-muted">Standard: 800 Hz</small>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">Kritische Warnung - Sound</label>
                                    <select class="form-select" @bind="_appSettings.SecondWarningSound">
                                        <option value="beep">🔔 Beep</option>
                                        <option value="bell">🔔 Glocke</option>
                                        <option value="alarm">🚨 Alarm (Standard)</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Frequenz (Hz)</label>
                                    <InputNumber @bind-Value="_appSettings.SecondWarningFrequency" class="form-control" min="200" max="2000" />
                                    <small class="text-muted">Standard: 1200 Hz</small>
                                </div>
                            </div>

                            <div class="form-check form-switch mb-3">
                                <InputCheckbox @bind-Value="_appSettings.RepeatSecondWarning" class="form-check-input" id="repeatWarning" />
                                <label class="form-check-label" for="repeatWarning">
                                    Kritische Warnung wiederholen
                                </label>
                            </div>

                            @if (_appSettings.RepeatSecondWarning)
                            {
                                <div class="form-group mb-3">
                                    <label class="form-label">Wiederholungs-Intervall (Sekunden)</label>
                                    <InputNumber @bind-Value="_appSettings.RepeatWarningIntervalSeconds" class="form-control" min="10" max="120" />
                                    <small class="text-muted">Standard: 30 Sekunden</small>
                                </div>
                            }

                            <div class="d-flex gap-2 mb-3">
                                <button type="button" class="btn btn-outline-primary" @onclick="TestFirstWarning">
                                    <i class="bi bi-play-fill"></i> Erste Warnung testen
                                </button>
                                <button type="button" class="btn btn-outline-danger" @onclick="TestSecondWarning">
                                    <i class="bi bi-play-fill"></i> Kritische Warnung testen
                                </button>
                            </div>
                        }

                        <hr/>

                        <h5 class="mb-3"><i class="bi bi-arrow-repeat"></i> Updates</h5>

                        <div class="form-group mb-3">
                            <label class="form-label">Update-URL</label>
                            <InputText @bind-Value="_appSettings.UpdateUrl" class="form-control form-control-lg" placeholder="https://..." />
                        </div>

                        <div class="form-check mb-3">
                            <InputCheckbox @bind-Value="_appSettings.AutoCheckUpdates" class="form-check-input" id="autoUpdate" />
                            <label class="form-check-label" for="autoUpdate">
                                Automatisch nach Updates suchen
                            </label>
                        </div>

                        <button type="submit" class="btn btn-success btn-lg w-100">
                            <i class="bi bi-save-fill"></i> Speichern
                        </button>
                    </EditForm>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h4><i class="bi bi-info-circle-fill"></i> System-Information</h4>
                </div>
                <div class="card-body">
                    <p><strong>Version:</strong> @_appVersion</p>
                    <p><strong>Framework:</strong> .NET 8 / Blazor Server</p>
                    <p><strong>Plattform:</strong> Web-basiert</p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private StaffelSettings _staffelSettings = new();
    private AppSettings _appSettings = new();
    private string _appVersion = "Unbekannt";

    protected override async Task OnInitializedAsync()
    {
        _appVersion = GetType().Assembly.GetName().Version?.ToString(3) ?? "Unbekannt";

        var sessionData = await MasterDataService.LoadSessionDataAsync();
        _staffelSettings = sessionData.StaffelSettings;
        _appSettings = sessionData.AppSettings;

        // Synchronisiere mit ThemeService
        await ThemeService.InitializeAsync();
    }

    private async Task SaveStaffelSettings()
    {
        try
        {
            var sessionData = await MasterDataService.LoadSessionDataAsync();
            sessionData.StaffelSettings = _staffelSettings;
            await MasterDataService.SaveSessionDataAsync(sessionData);
            ToastService.ShowSuccess("Staffel-Einstellungen wurden gespeichert");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Fehler beim Speichern: {ex.Message}");
        }
    }

    private async Task SaveAppSettings()
    {
        try
        {
            var sessionData = await MasterDataService.LoadSessionDataAsync();
            sessionData.AppSettings = _appSettings;
            await MasterDataService.SaveSessionDataAsync(sessionData);
            
            await ApplyTheme();
            
            // Aktualisiere Audio-Einstellungen
            await JS.InvokeVoidAsync("AudioAlerts.updateSettings", new
            {
                soundAlertsEnabled = _appSettings.SoundAlertsEnabled,
                soundVolume = _appSettings.SoundVolume,
                firstWarningSound = _appSettings.FirstWarningSound,
                secondWarningSound = _appSettings.SecondWarningSound,
                firstWarningFrequency = _appSettings.FirstWarningFrequency,
                secondWarningFrequency = _appSettings.SecondWarningFrequency,
                repeatSecondWarning = _appSettings.RepeatSecondWarning,
                repeatWarningIntervalSeconds = _appSettings.RepeatWarningIntervalSeconds
            });
            
            ToastService.ShowSuccess("App-Einstellungen wurden gespeichert");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Fehler beim Speichern: {ex.Message}");
        }
    }

    private async Task ToggleDarkMode(bool isDark)
    {
        _appSettings.IsDarkMode = isDark;
        _appSettings.Theme = isDark ? "Dark" : "Light";
        
        // Speichere in SessionData
        var sessionData = await MasterDataService.LoadSessionDataAsync();
        sessionData.AppSettings = _appSettings;
        await MasterDataService.SaveSessionDataAsync(sessionData);
        
        // ZUERST: Broadcast an alle Tabs (aktualisiert localStorage und wendet Theme an)
        await JS.InvokeVoidAsync("broadcastThemeChange", isDark ? "dark" : "light");
        
        // DANN: Update ThemeService (für interne State-Konsistenz)
        await ThemeService.SetThemeAsync(isDark);
        
        StateHasChanged();
    }

    private async Task ApplyTheme()
    {
        try
        {
            var theme = _appSettings.IsDarkMode ? "dark" : "light";
            
            // Broadcast Theme-änderung an alle Tabs/Fenster
            await JS.InvokeVoidAsync("broadcastThemeChange", theme);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fehler beim Anwenden des Themes: {ex.Message}");
        }
    }

    private void OnThemeModeChanged()
    {
        // Bei Wechsel zu Auto oder Scheduled, Theme sofort anwenden
        if (_appSettings.ThemeMode == "Auto")
        {
            // System-Theme ermitteln (vereinfacht - verwendet aktuelle Zeit)
            var hour = DateTime.Now.Hour;
            _appSettings.IsDarkMode = hour < 6 || hour >= 20;
        }
        else if (_appSettings.ThemeMode == "Scheduled")
        {
            // Prüfe ob wir aktuell in Dark Mode Zeit sind
            var now = DateTime.Now.TimeOfDay;
            var start = _appSettings.DarkModeStartTime;
            var end = _appSettings.DarkModeEndTime;

            if (start < end)
            {
                _appSettings.IsDarkMode = now >= start && now < end;
            }
            else
            {
                _appSettings.IsDarkMode = now >= start || now < end;
            }
        }
        StateHasChanged();
    }

    private string FormatTimeSpan(TimeSpan time)
    {
        return $"{time.Hours:D2}:{time.Minutes:D2}";
    }

    private TimeSpan ParseTimeSpan(string? timeString)
    {
        if (string.IsNullOrEmpty(timeString))
            return TimeSpan.Zero;

        if (TimeSpan.TryParse(timeString, out var result))
            return result;

        return TimeSpan.Zero;
    }

    private void OnVolumeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var volume))
        {
            _appSettings.SoundVolume = volume;
        }
    }

    private async Task TestFirstWarning()
    {
        try
        {
            // Aktualisiere Audio-Einstellungen
            await JS.InvokeVoidAsync("AudioAlerts.updateSettings", new
            {
                soundAlertsEnabled = _appSettings.SoundAlertsEnabled,
                soundVolume = _appSettings.SoundVolume,
                firstWarningSound = _appSettings.FirstWarningSound,
                firstWarningFrequency = _appSettings.FirstWarningFrequency
            });
            
            // Spiele erste Warnung ab
            await JS.InvokeVoidAsync("AudioAlerts.playFirstWarning");
            ToastService.ShowInfo("Erste Warnung abgespielt");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Fehler: {ex.Message}");
        }
    }

    private async Task TestSecondWarning()
    {
        try
        {
            // Aktualisiere Audio-Einstellungen
            await JS.InvokeVoidAsync("AudioAlerts.updateSettings", new
            {
                soundAlertsEnabled = _appSettings.SoundAlertsEnabled,
                soundVolume = _appSettings.SoundVolume,
                secondWarningSound = _appSettings.SecondWarningSound,
                secondWarningFrequency = _appSettings.SecondWarningFrequency,
                repeatSecondWarning = false // Beim Test nicht wiederholen
            });
            
            // Spiele kritische Warnung ab
            await JS.InvokeVoidAsync("AudioAlerts.playSecondWarning");
            ToastService.ShowWarning("Kritische Warnung abgespielt");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Fehler: {ex.Message}");
        }
    }
}
