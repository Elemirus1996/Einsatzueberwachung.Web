@page "/drohne"
@using System.Globalization
@using Einsatzueberwachung.Domain.Interfaces
@inject IEinsatzService EinsatzService
@implements IDisposable

<PageTitle>Drohne | Einsatzüberwachung</PageTitle>

<div class="container-fluid">
    <div class="page-header mb-4">
        <h1><i class="bi bi-airplane-fill me-2"></i>Drohne</h1>
        <p class="text-muted mb-0">Drohnenwetter für den aktuellen Einsatzstandort</p>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-lg-5">
                    <label class="form-label fw-bold">Einsatzadresse</label>
                    <input class="form-control" value="@_address" readonly />
                </div>
                <div class="col-md-3 col-lg-2">
                    <label class="form-label fw-bold">Breitengrad</label>
                    <input class="form-control" value="@FormatCoord(_latitude)" readonly />
                </div>
                <div class="col-md-3 col-lg-2">
                    <label class="form-label fw-bold">Laengengrad</label>
                    <input class="form-control" value="@FormatCoord(_longitude)" readonly />
                </div>
                <div class="col-md-6 col-lg-3 d-grid gap-2">
                    <button type="button" class="btn btn-primary w-100" @onclick="RefreshNow" disabled="@(!_hasLocationData)">
                        <i class="bi bi-arrow-clockwise me-1"></i>Jetzt neu laden
                    </button>
                    <a class="btn btn-outline-secondary w-100" href="https://drohnenwetter.de/" target="_blank" rel="noopener noreferrer">
                        <i class="bi bi-box-arrow-up-right me-1"></i>Extern öffnen
                    </a>
                </div>
            </div>

            @if (!_hasLocationData)
            {
                <div class="alert alert-warning mt-3 mb-0">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Kein Einsatzstandort vorhanden. Bitte zuerst Einsatzort oder ELW-Position setzen.
                </div>
            }

            <div class="small text-muted mt-3">
                Letzte Aktualisierung: @_lastRefresh.ToString("dd.MM.yyyy HH:mm:ss") Uhr · Automatisch alle 5 Minuten
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <iframe
                name="drohnenwetter-frame"
                src="@_iframeUrl"
                title="Drohnenwetter"
                style="width:100%; min-height:75vh; border:0; border-radius:0.5rem;">
            </iframe>
        </div>
    </div>
</div>

@code {
    private const string DrohnenwetterResultsUrl = "https://drohnenwetter.de/results";
    private string _address = string.Empty;
    private double? _latitude;
    private double? _longitude;
    private bool _hasLocationData;
    private DateTime _lastRefresh = DateTime.Now;
    private string _iframeUrl = "https://drohnenwetter.de/";
    private CancellationTokenSource? _reloadCts;

    protected override void OnInitialized()
    {
        EinsatzService.EinsatzChanged += OnEinsatzChanged;
        UpdateFromCurrentEinsatz();
        _reloadCts = new CancellationTokenSource();
        _ = StartAutoReloadLoopAsync(_reloadCts.Token);
    }

    private async Task StartAutoReloadLoopAsync(CancellationToken token)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromMinutes(5));
            while (await timer.WaitForNextTickAsync(token))
            {
                await InvokeAsync(() =>
                {
                    UpdateFromCurrentEinsatz();
                    BuildIframeUrl();
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
            // Erwartet beim Verlassen der Seite
        }
    }

    private void OnEinsatzChanged()
    {
        _ = InvokeAsync(() =>
        {
            UpdateFromCurrentEinsatz();
            BuildIframeUrl();
            StateHasChanged();
        });
    }

    private void UpdateFromCurrentEinsatz()
    {
        var einsatz = EinsatzService.CurrentEinsatz;

        _latitude = einsatz.ElwLatitude;
        _longitude = einsatz.ElwLongitude;
        _address = string.IsNullOrWhiteSpace(einsatz.MapAddress)
            ? einsatz.Einsatzort
            : einsatz.MapAddress;

        _hasLocationData =
            (!string.IsNullOrWhiteSpace(_address)) ||
            (_latitude.HasValue && _longitude.HasValue);
    }

    private Task RefreshNow()
    {
        UpdateFromCurrentEinsatz();
        BuildIframeUrl();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void BuildIframeUrl()
    {
        if (!_hasLocationData)
        {
            _iframeUrl = "https://drohnenwetter.de/";
            _lastRefresh = DateTime.Now;
            return;
        }

        var address = string.IsNullOrWhiteSpace(_address) ? "GPS" : _address;
        var lat = FormatCoord(_latitude);
        var lon = FormatCoord(_longitude);
        var ts = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();

        _iframeUrl =
            $"{DrohnenwetterResultsUrl}?address={Uri.EscapeDataString(address)}&lat={lat}&lon={lon}&_ts={ts}";
        _lastRefresh = DateTime.Now;
    }

    private static string FormatCoord(double? value)
    {
        return value.HasValue
            ? value.Value.ToString("F6", CultureInfo.InvariantCulture)
            : string.Empty;
    }

    public void Dispose()
    {
        EinsatzService.EinsatzChanged -= OnEinsatzChanged;
        _reloadCts?.Cancel();
        _reloadCts?.Dispose();
    }
}