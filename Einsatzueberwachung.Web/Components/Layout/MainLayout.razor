@inherits LayoutComponentBase
@using Einsatzueberwachung.Domain.Interfaces
@using Einsatzueberwachung.Domain.Services
@using Microsoft.Extensions.Logging
@inject ThemeService ThemeService
@inject IJSRuntime JS
@inject ILogger<MainLayout> Logger
@inject NavigationManager Navigation
@implements IDisposable

<a href="#main-content" class="skip-link">Zum Hauptinhalt springen</a>

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main id="main-content" role="main">
        <div class="top-row px-4 header-with-clock">
            <div class="live-datetime" id="live-datetime">
                <span class="live-time" id="live-time" style="font-size: 1.2rem; font-weight: 600;">--:--:--</span>
                <span class="live-date" id="live-date" style="font-size: 0.95rem; opacity: 0.9;">--.--.----</span>
            </div>
            <div class="header-actions">
                <button type="button" class="btn-fullscreen" id="btn-fullscreen" title="Vollbild-Modus (F11)">
                    <i class="bi bi-arrows-fullscreen" id="fullscreen-icon"></i>
                </button>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private DotNetObjectReference<MainLayout>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        // Initialisiere Theme Service
        await ThemeService.InitializeAsync();
        
        // Subscribe to theme changes
        ThemeService.OnThemeChanged += OnThemeChangedHandler;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Beim ersten Render das gespeicherte Theme anwenden
            await JS.InvokeVoidAsync("forceApplyTheme");
            
            // Keyboard Shortcuts initialisieren
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("KeyboardShortcuts.initialize", _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task HandleShortcut(string action)
    {
        Logger.LogDebug("Keyboard shortcut: {Action}", action);
        
        switch (action)
        {
            case "navigateHome":
                Navigation.NavigateTo("/");
                break;
            case "navigateMap":
                Navigation.NavigateTo("/einsatz/karte");
                break;
            case "navigateReport":
                Navigation.NavigateTo("/einsatz/bericht");
                break;
            case "navigateMonitor":
                Navigation.NavigateTo("/einsatz/monitor");
                break;
            case "navigateStammdaten":
                Navigation.NavigateTo("/stammdaten");
                break;
            case "toggleDarkMode":
                await ThemeService.ToggleThemeAsync();
                break;
            // Andere Aktionen werden von den jeweiligen Seiten behandelt
        }
    }

    private async void OnThemeChangedHandler()
    {
        // Theme wird bereits von broadcastThemeChange angewendet
        // Hier nur StateHasChanged für Blazor-UI-Updates
        await InvokeAsync(() =>
        {
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= OnThemeChangedHandler;
        _dotNetRef?.Dispose();
    }
}
