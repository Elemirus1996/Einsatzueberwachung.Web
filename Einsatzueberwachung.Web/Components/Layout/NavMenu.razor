@code {
    private bool _isDarkMode = false;
    private bool _isInitialized = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await ThemeService.InitializeAsync();
            _isDarkMode = ThemeService.IsDarkMode;
            _isInitialized = true;
            
            // Subscribe to theme changes
            ThemeService.OnThemeChanged += OnThemeChangedHandler;
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fehler bei Theme-Initialisierung: {ex.Message}");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            // Wende Sidebar-Status bei jedem Render an (wichtig für Navigation)
            await JS.InvokeVoidAsync("applySidebarState");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fehler beim Laden des Sidebar-Status: {ex.Message}");
        }
    }

    private async void OnThemeChangedHandler()
    {
        await InvokeAsync(() =>
        {
            _isDarkMode = ThemeService.IsDarkMode;
            StateHasChanged();
        });
    }

    private async Task ToggleTheme()
    {
        if (!_isInitialized)
        {
            Console.WriteLine("Theme-Service noch nicht initialisiert");
            return;
        }

        try
        {
            // Berechne neues Theme
            var newTheme = ThemeService.IsDarkMode ? "light" : "dark";
            
            // ZUERST: Broadcast Theme-Änderung an alle Tabs/Fenster
            await JS.InvokeVoidAsync("broadcastThemeChange", newTheme);
            
            // DANN: Update ThemeService (für interne State-Konsistenz)
            await ThemeService.ToggleThemeAsync();
            _isDarkMode = ThemeService.IsDarkMode;
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fehler beim Umschalten des Themes: {ex.Message}");
        }
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= OnThemeChangedHandler;
    }
}

