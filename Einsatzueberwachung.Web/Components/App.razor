<!DOCTYPE html>
<html lang="en" data-bs-theme="light">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content="Tablet-optimierte Rettungshunde Einsatzüberwachung" />
    <meta name="theme-color" content="#2196F3" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Einsatzüberwachung" />
    <base href="/" />
    
    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json" />
    
    <!-- Bootstrap 5.3+ für Dark Mode Support -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" 
          integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" 
          crossorigin="anonymous">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">
    <!-- Dark Mode Base Styles -->
    <link rel="stylesheet" href="/dark-mode-base.css?v=4.1.0" />
    <link rel="stylesheet" href="/app.css?v=4.1.0" />
    <link rel="stylesheet" href="/notes-enhanced.css?v=4.1.0" />
    <link rel="stylesheet" href="/mobile-dashboard.css?v=4.1.0" />
    <link rel="stylesheet" href="/print-map.css?v=4.1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" 
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" 
          crossorigin="" />
    
    <!-- Leaflet Draw CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.css" />
    
    <!-- Leaflet Custom CSS -->
    <link rel="stylesheet" href="/leaflet-custom.css?v=4.1.0" />
    
    <HeadOutlet />
    
    <!-- Theme Loader Script - Lädt VOR Blazor -->
    <script>
        (function() {
            try {
                // Lade Theme aus localStorage
                var savedTheme = localStorage.getItem('theme');
                if (savedTheme) {
                    document.documentElement.setAttribute('data-bs-theme', savedTheme);
                    console.log('Theme geladen:', savedTheme);
                } else {
                    console.log('Kein gespeichertes Theme gefunden, verwende light');
                }
            } catch (e) {
                console.error('Fehler beim Laden des Themes:', e);
            }
        })();
        
        // Sidebar Status Loader - wird bei jedem Seitenwechsel aufgerufen
        window.applySidebarState = function() {
            var collapsed = localStorage.getItem('sidebarCollapsed') === 'true';
            var page = document.querySelector('.page');
            if (page) {
                if (collapsed) {
                    page.classList.add('sidebar-collapsed');
                } else {
                    page.classList.remove('sidebar-collapsed');
                }
            }
        };
        
        // Toggle Sidebar Funktion (CSP-kompatibel)
        window.toggleSidebar = function() {
            var page = document.querySelector('.page');
            if (page) {
                page.classList.toggle('sidebar-collapsed');
                localStorage.setItem('sidebarCollapsed', page.classList.contains('sidebar-collapsed'));
            }
        };
        
        // Event Delegation für Sidebar-Toggle (CSP-kompatibel, funktioniert auch nach Blazor-Navigation)
        document.addEventListener('click', function(e) {
            if (e.target.closest('.btn-sidebar-toggle')) {
                window.toggleSidebar();
            }
            if (e.target.closest('.btn-fullscreen')) {
                window.toggleFullscreen();
            }
        });
        
        // Fullscreen Toggle Funktion
        window.toggleFullscreen = function() {
            if (!document.fullscreenElement) {
                document.documentElement.requestFullscreen().catch(function(err) {
                    console.log('Fullscreen nicht möglich:', err.message);
                });
            } else {
                document.exitFullscreen();
            }
        };
        
        // Fullscreen Icon aktualisieren
        document.addEventListener('fullscreenchange', function() {
            var icon = document.getElementById('fullscreen-icon');
            if (icon) {
                if (document.fullscreenElement) {
                    icon.className = 'bi bi-fullscreen-exit';
                } else {
                    icon.className = 'bi bi-arrows-fullscreen';
                }
            }
        });
        
        // F11 Taste abfangen für Vollbild
        document.addEventListener('keydown', function(e) {
            if (e.key === 'F11') {
                e.preventDefault();
                window.toggleFullscreen();
            }
        });
        
        // Initial und bei DOM-Änderungen anwenden
        document.addEventListener('DOMContentLoaded', function() {
            window.applySidebarState();
        });
        
        // MutationObserver für Blazor-Navigation
        var sidebarObserver = new MutationObserver(function(mutations) {
            window.applySidebarState();
        });
        
        // Observer starten wenn DOM bereit
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', function() {
                sidebarObserver.observe(document.body, { childList: true, subtree: true });
            });
        } else {
            sidebarObserver.observe(document.body, { childList: true, subtree: true });
        }
    </script>
</head>

<body>
    <!-- Splash Screen -->
    <div id="splash-screen" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(135deg, #1a237e 0%, #0d47a1 50%, #1565c0 100%); display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 99999; transition: opacity 0.5s ease-out;">
        <img src="/logo.png" alt="Logo" style="width: 180px; height: 180px; margin-bottom: 2rem; animation: pulse 2s ease-in-out infinite;" />
        <h1 style="color: white; font-size: 1.8rem; font-weight: 600; margin-bottom: 1rem; text-align: center;">Einsatzüberwachung</h1>
        <div style="color: rgba(255,255,255,0.8); font-size: 1rem; margin-bottom: 2rem;">Rettungshunde-Einsatz-Koordination</div>
        <div style="width: 200px; height: 4px; background: rgba(255,255,255,0.2); border-radius: 2px; overflow: hidden;">
            <div style="width: 100%; height: 100%; background: white; border-radius: 2px; animation: loading 1.5s ease-in-out infinite;"></div>
        </div>
    </div>
    <style>
        @@keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.05); opacity: 0.9; }
        }
        @@keyframes loading {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }
    </style>
    <script>
        // Splash Screen ausblenden wenn Blazor geladen ist
        document.addEventListener('DOMContentLoaded', function() {
            var checkBlazor = setInterval(function() {
                var blazorContent = document.querySelector('.page');
                if (blazorContent) {
                    clearInterval(checkBlazor);
                    var splash = document.getElementById('splash-screen');
                    if (splash) {
                        splash.style.opacity = '0';
                        setTimeout(function() { splash.remove(); }, 500);
                    }
                }
            }, 100);
            // Fallback: Nach 5 Sekunden trotzdem ausblenden
            setTimeout(function() {
                var splash = document.getElementById('splash-screen');
                if (splash) {
                    splash.style.opacity = '0';
                    setTimeout(function() { splash.remove(); }, 500);
                }
            }, 5000);
        });
    </script>

    <Routes />
    
    <!-- Update Notification Component -->
    <UpdateNotificationComponent />
    
    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" 
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" 
            crossorigin=""></script>
    
    <!-- Leaflet Draw JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.js"></script>
    
    <!-- Custom Leaflet Interop -->
    <script src="/leaflet-interop.js?v=4.1.0"></script>
    
    <!-- Audio Alerts System -->
    <script src="/audio-alerts.js?v=4.1.0"></script>
    
    <!-- Theme Sync System -->
    <script src="/theme-sync.js?v=4.1.0"></script>
    
    <!-- QR Code Loader System -->
    <script src="/load-qrcodes.js?v=4.1.0"></script>
    
    <!-- Live Clock System -->
    <script src="/js/clock.js?v=4.1.0"></script>
    
    <!-- Service Worker Manager -->
    <script src="/service-worker-manager.js?v=4.1.0"></script>
    
    <!-- Swipe Handler -->
    <script src="/swipe-handler.js?v=4.1.0"></script>
    
    <!-- Keyboard Shortcuts System -->
    <script src="/keyboard-shortcuts.js?v=4.1.0"></script>
    
    <!-- Multi-Monitor Support -->
    <script src="/multi-monitor.js?v=4.1.0"></script>
    
    <!-- File Download Helper für Excel Export -->
    <script src="/file-download.js?v=4.1.0"></script>
    
    <!-- Sidebar Toggle -->
    <script src="/sidebar.js?v=4.1.0"></script>
    
    <script src="_framework/blazor.web.js"></script>

    <!-- One-time Cache/Service Worker reset for updated assets -->
    <script>
        (async function () {
            try {
                const resetKey = 'sw-reset-2026-02-03';
                if (!localStorage.getItem(resetKey)) {
                    if ('serviceWorker' in navigator) {
                        const regs = await navigator.serviceWorker.getRegistrations();
                        for (const reg of regs) {
                            await reg.unregister();
                        }
                    }
                    if ('caches' in window) {
                        const keys = await caches.keys();
                        await Promise.all(keys.map(k => caches.delete(k)));
                    }
                    localStorage.setItem(resetKey, '1');
                    location.reload();
                }
            } catch (e) {
                console.warn('Service Worker reset skipped:', e);
            }
        })();
    </script>
    
    <!-- Initialize Clock nach Blazor -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            initializeClock();
        });
        
        // Fallback - auch sofort aufrufen falls bereits geladen
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', function() {
                initializeClock();
            });
        } else {
            // DOM ist bereits geladen
            setTimeout(function() {
                if (window.initializeClock) {
                    initializeClock();
                }
            }, 100);
        }
    </script>
</body>

</html>

